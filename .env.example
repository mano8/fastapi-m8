# ── Core ─────────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local            # local | development | staging | production
PROJECT_NAME=my-service
STACK_NAME=local
API_PREFIX=/api
AUTH_PREFIX=/auth
BACKEND_HOST=http://localhost:8000
FRONTEND_HOST=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Host validation (F8 · TrustedHostMiddleware) ──────────────────────────────
# Comma-separated allowlist for the Host header. Empty = no restriction (dev default).
# In production set to your public hostname(s) to prevent host-header injection.
# testserver is auto-added in non-production so pytest TestClient works.
ALLOWED_HOSTS=

# ── OpenAPI / Docs ────────────────────────────────────────────────────────────
# Raw flags — whether the operator wants these endpoints at all.
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# Secure-by-default: docs are DISABLED in production (ENVIRONMENT=production or
# STRICT_PRODUCTION_MODE=true) regardless of the SET_* flags above, UNLESS this
# is set to true. Use for public/open-source APIs that intentionally publish docs.
# Requires auth-sdk-m8>=0.7.3.
SERVE_DOCS_IN_PRODUCTION=false

# Override: treat this environment as production even when ENVIRONMENT!=production.
# When true, docs gating and fail-closed revocation are always active.
STRICT_PRODUCTION_MODE=false

# ── Tokens & Cryptography ─────────────────────────────────────────────────────
# Secure-by-default (auth-sdk-m8>=1.0.0): RS256 access tokens, strict iss/aud
# binding, and HMAC-signed event bus. Opt-outs are documented inline below.
TOKEN_MODE=stateless          # stateless | hybrid | stateful
AUTH_SERVICE_ROLE=consumer    # always "consumer" for fastapi-m8 services
ACCESS_TOKEN_ALGORITHM=RS256  # RS256 (default) | ES256 | HS256 (opt-in shared secret)
REFRESH_SECRET_KEY=change-me-refresh-32-chars-min  # always HS256, internal

# RS256/ES256: supply the issuer's PUBLIC key (consumers only validate).
# Mount as a read-only volume in Docker, or use JWKS for zero-downtime rotation.
ACCESS_PUBLIC_KEY_FILE=/opt/keys/access_public.pem
# JWKS_URI=https://auth.example.com/.well-known/jwks.json
# JWKS_CACHE_TTL_SECONDS=300

# Strict iss/aud binding is ON by default and REQUIRED at boot when enabled.
# Both services must agree on these values.
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=my-service
# Opt out for single-service/dev (then HS256 + ACCESS_SECRET_KEY is sufficient):
# TOKEN_STRICT_VALIDATION=false
# ACCESS_TOKEN_ALGORITHM=HS256
# ACCESS_SECRET_KEY=change-me-32-chars-minimum

# ── Event signing ─────────────────────────────────────────────────────────────
# Secure-by-default: SSE event payloads are HMAC-SHA256 signed. EVENT_SIGNING_KEY
# is required at boot unless signing is disabled. Must match the value set on fa-auth.
# DEV-ONLY placeholder — replace in staging/production.
EVENT_SIGNING_KEY=DEV-ONLY-do-not-use-event-signing-key-Aa1!
# EVENT_SIGNING_ENABLED=false           # disable signing entirely (opt-out)
# EVENT_SIGNING_ACCEPT_UNSIGNED=false   # transitional: accept signed AND unsigned

# ── Auth event stream (fa-auth SSE bridge) ────────────────────────────────────
# Optional: start AuthEventStreamClient in lifespan for best-effort cache
# acceleration (session-revoked / user-deleted events). The JTI blacklist via
# INTROSPECTION_URL remains the revocation authority — the stream is additive.
# Requires TOKEN_MODE=stateful (INTROSPECTION_URL + PRIVATE_API_SECRET set above).
# EVENT_STREAM_CONNECT_TIMEOUT=5        # seconds to wait for initial connection
# EVENT_STREAM_READ_TIMEOUT=60          # seconds between SSE frames (keep > fa-auth heartbeat)

# ── Stateful mode (consumer → fa-auth-m8) ────────────────────────────────────
# Required only when TOKEN_MODE=stateful and AUTH_SERVICE_ROLE=consumer.
# INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
# PRIVATE_API_SECRET=change-me-shared-internal-secret

# Revocation failure mode: fail_closed (default, secure) or fail_open (availability).
# ACCESS_REVOCATION_FAILURE_MODE=fail_closed

# ── Database ──────────────────────────────────────────────────────────────────
SELECTED_DB=Mysql             # Mysql | Postgres
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=my_service
DB_USER=app_user
DB_PASSWORD=change-me
TABLES_PREFIX=app

# ── Redis (stateful/hybrid issuer only — not used by consumer services) ───────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=redisuser
REDIS_PASSWORD=change-me
REDIS_SSL=false

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=false
# METRICS_GROUPS=traffic,performance,reliability,health,auth
